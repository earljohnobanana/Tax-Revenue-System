{
  "name": "kind_of_market_and_tax_due",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.js",
  "scripts": {
    "dev:client": "npm --prefix sta-catalina-btrf run dev",
    "dev:server": "nodemon server/server.js",
    "dev:electron": "wait-on http://127.0.0.1:5000/api/health http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\" \"npm:dev:electron\"",
    "build:client": "npm --prefix sta-catalina-btrf run build",
    "start": "cross-env NODE_ENV=production electron .",
    "package:win": "npm run build:client && electron-builder --win"
  },
  "build": {
    "appId": "ph.gov.bpls.desktop",
    "productName": "Santa Catalina Revenue System",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "files": [
      "sta-catalina-btrf/dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json",
      "build/icon.ico"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "node-cron": "^4.5.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "nodemon": "^3.1.14",
    "wait-on": "^9.0.10"
  }
}